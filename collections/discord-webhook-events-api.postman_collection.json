  "info": {
    "_postman_id": "a76d32e9-dd93-4f93-8fa1-59e5fe44095e",
    "name": "Discord Webhook Events API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Discord Webhook Events API provides HTTP-based outgoing webhook events that allow applications to receive notifications for specific events without maintaining a persistent connection. Supported events include APPLICATION_AUTHORIZED, ENTITLEMENT_CREATE, and QUEST_USER_ENROLLMENT. Events are sent as POST requests to the application's configured event webhook URL.\n\nContact Support:\n Name: Discord Support\n Email: support@discord.com",
      "type": "text/plain"
    }
