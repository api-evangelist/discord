  "info": {
    "_postman_id": "53c985bc-0748-4557-b2ed-3ecfd0b465c7",
    "name": "Discord Linked Roles API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Discord Linked Roles API enables applications to associate third-party metadata with Discord users through role connection metadata. Server admins can use this metadata to configure requirements for linked roles, such as verified accounts or achievement thresholds from external platforms.\n\nContact Support:\n Name: Discord Support\n Email: support@discord.com",
      "type": "text/plain"
    }
  }
