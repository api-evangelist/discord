{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GithubDiscussion",
  "title": "GithubDiscussion",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 152133
    },
    "number": {
      "type": "integer"
    },
    "html_url": {
      "type": "string",
      "maxLength": 2048,
      "format": "uri"
    },
    "answer_html_url": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2048,
      "format": "uri"
    },
    "body": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 152133
    },
    "user": {
      "$ref": "#/components/schemas/GithubUser"
    }
  },
  "required": [
    "title",
    "number",
    "html_url",
    "user"
  ]
}