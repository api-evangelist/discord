{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SelectOption",
  "title": "SelectOption",
  "type": "object",
  "properties": {
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "value": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    },
    "emoji": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/Emoji"
        }
      ]
    },
    "default": {
      "type": [
        "boolean",
        "null"
      ]
    }
  },
  "required": [
    "label",
    "value"
  ]
}