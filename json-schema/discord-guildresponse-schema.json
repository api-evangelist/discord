  "required": [
    "id",
    "name",
    "features",
    "owner_id",
    "region",
    "afk_timeout",
    "system_channel_flags",
    "widget_enabled",
    "verification_level",
    "roles",
    "default_message_notifications",
    "mfa_level",
    "explicit_content_filter",
    "premium_tier",
    "premium_subscription_count",
    "preferred_locale",
    "premium_progress_bar_enabled",
    "nsfw",
    "nsfw_level",
    "emojis",
    "stickers"
