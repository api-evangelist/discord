        "boolean",
        "null"
      ]
    },
    "system": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "banner": {
      "type": [
        "string",
        "null"
      ]
    },
    "accent_color": {
      "type": [
        "integer",
        "null"
