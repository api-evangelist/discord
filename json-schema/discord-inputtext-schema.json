{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/InputText",
  "title": "InputText",
  "type": "object",
  "properties": {
    "type": {
      "type": "integer",
      "enum": [
        4
      ],
      "allOf": [
        {
          "$ref": "#/components/schemas/MessageComponentTypes"
        }
      ],
      "format": "int32"
    },
    "custom_id": {
      "type": "string",
      "maxLength": 100
    },
    "style": {
      "$ref": "#/components/schemas/TextStyleTypes"
    },
    "label": {
      "type": "string",
      "maxLength": 45
    },
    "value": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 4000
    },
    "placeholder": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    },
    "required": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "min_length": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "maximum": 4000
    },
    "max_length": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 4000
    }
  },
  "required": [
    "type",
    "custom_id",
    "style",
    "label"
  ]
}