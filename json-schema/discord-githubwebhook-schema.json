    },
    "review": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/GithubReview"
        }
      ]
    },
    "check_run": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/GithubCheckRun"
        }
      ]
    },
    "check_suite": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/GithubCheckSuite"
        }
      ]
    },
    "discussion": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/GithubDiscussion"
        }
      ]
    },
    "answer": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/GithubComment"
