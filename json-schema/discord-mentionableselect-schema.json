{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MentionableSelect",
  "title": "MentionableSelect",
  "type": "object",
  "properties": {
    "type": {
      "type": "integer",
      "enum": [
        7
      ],
      "allOf": [
        {
          "$ref": "#/components/schemas/MessageComponentTypes"
        }
      ],
      "format": "int32"
    },
    "custom_id": {
      "type": "string",
      "maxLength": 100
    },
    "placeholder": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 150
    },
    "min_values": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "maximum": 25
    },
    "max_values": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 25
    },
    "disabled": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "default_values": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/RoleSelectDefaultValue"
          },
          {
            "$ref": "#/components/schemas/UserSelectDefaultValue"
          }
        ]
      },
      "maxItems": 25
    }
  },
  "required": [
    "type",
    "custom_id"
  ]
}