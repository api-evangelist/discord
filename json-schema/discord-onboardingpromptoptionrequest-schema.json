{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/OnboardingPromptOptionRequest",
  "title": "OnboardingPromptOptionRequest",
  "type": "object",
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/SnowflakeType"
        }
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    },
    "emoji_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/components/schemas/SnowflakeType"
        }
      ]
    },
    "emoji_name": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 100
    },
    "emoji_animated": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "role_ids": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/components/schemas/SnowflakeType"
      },
      "maxItems": 50,
      "uniqueItems": true
    },
    "channel_ids": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/components/schemas/SnowflakeType"
      },
      "maxItems": 50,
      "uniqueItems": true
    }
  },
  "required": [
    "title"
  ]
}